# Local environment variables (copy to .env)
# PUBLIC_ prefix = exposed to client-side code

# Site URL (update after deploying)
SITE=https://my-blog.vercel.app

# Giscus comments — configure at https://giscus.app
# PUBLIC_GISCUS_REPO=your-username/my-blog
# PUBLIC_GISCUS_REPO_ID=
# PUBLIC_GISCUS_CATEGORY=Announcements
# PUBLIC_GISCUS_CATEGORY_ID=

# Umami analytics — configure at https://umami.is
# PUBLIC_UMAMI_WEBSITE_ID=
# PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js
