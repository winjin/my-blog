---
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../consts';

const posts = (await getCollection('posts'))
  .filter((post) => !post.data.draft)
  .map((post) => ({
    title: post.data.title,
    description: post.data.description,
    url: `/posts/${post.id}/`,
    category: CATEGORIES[post.data.category].label,
    tags: post.data.tags,
  }));
---

<div id="search-modal" class="search-modal" hidden aria-hidden="true">
  <div class="search-backdrop" data-search-close></div>
  <div class="search-panel" role="dialog" aria-modal="true" aria-labelledby="search-modal-title">
    <div class="search-panel-header">
      <svg class="search-panel-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
        <path d="M20 20L16.5 16.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
      </svg>
      <input
        id="search-input"
        class="search-input"
        type="search"
        placeholder="搜索文章标题、摘要、标签…"
        autocomplete="off"
        spellcheck="false"
      />
      <button type="button" class="search-close" data-search-close aria-label="关闭搜索">Esc</button>
    </div>
    <p id="search-modal-title" class="search-hint">输入关键词，方向键选择，Enter 打开文章</p>
    <ul id="search-results" class="search-results" role="listbox" aria-label="搜索结果"></ul>
    <p id="search-empty" class="search-empty" hidden>没有找到匹配的文章</p>
    <p class="search-footer">
      需要全文搜索？前往 <a href="/search">高级搜索页</a>
    </p>
  </div>
</div>

<script define:vars={{ posts }}>
  const modal = document.getElementById('search-modal');
  const input = document.getElementById('search-input');
  const resultsEl = document.getElementById('search-results');
  const emptyEl = document.getElementById('search-empty');
  const openBtn = document.getElementById('search-open');
  let activeIndex = -1;

  function normalize(text) {
    return (text || '').toLowerCase();
  }

  function matchPosts(query) {
    const q = normalize(query.trim());
    if (!q) return [];

    return posts.filter((post) => {
      const haystack = normalize([
        post.title,
        post.description,
        post.category,
        ...(post.tags || []),
      ].join(' '));
      return haystack.includes(q);
    });
  }

  function renderResults(items) {
    resultsEl.innerHTML = '';
    activeIndex = items.length ? 0 : -1;

    if (!input.value.trim()) {
      emptyEl.hidden = true;
      emptyEl.textContent = '没有找到匹配的文章';
      return;
    }

    if (items.length === 0) {
      emptyEl.hidden = false;
      return;
    }

    emptyEl.hidden = true;

    items.forEach((post, index) => {
      const li = document.createElement('li');
      li.className = 'search-result-item' + (index === activeIndex ? ' is-active' : '');
      li.setAttribute('role', 'option');
      li.dataset.index = String(index);
      li.innerHTML = `
        <a href="${post.url}">
          <span class="search-result-title">${post.title}</span>
          <span class="search-result-meta">${post.category}${post.tags?.length ? ' · ' + post.tags.slice(0, 3).join('、') : ''}</span>
          <span class="search-result-desc">${post.description}</span>
        </a>
      `;
      resultsEl.appendChild(li);
    });
  }

  function openModal() {
    modal.hidden = false;
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    input.value = '';
    renderResults([]);
    requestAnimationFrame(() => input.focus());
  }

  function closeModal() {
    modal.hidden = true;
    modal.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    activeIndex = -1;
  }

  function updateActiveItem(items) {
    const nodes = resultsEl.querySelectorAll('.search-result-item');
    nodes.forEach((node, index) => {
      node.classList.toggle('is-active', index === activeIndex);
    });
    const active = nodes[activeIndex];
    if (active) active.scrollIntoView({ block: 'nearest' });
  }

  openBtn?.addEventListener('click', openModal);

  document.querySelectorAll('[data-search-close]').forEach((el) => {
    el.addEventListener('click', closeModal);
  });

  input?.addEventListener('input', () => {
    renderResults(matchPosts(input.value));
  });

  input?.addEventListener('keydown', (event) => {
    const items = matchPosts(input.value);

    if (event.key === 'Escape') {
      event.preventDefault();
      closeModal();
      return;
    }

    if (event.key === 'ArrowDown') {
      event.preventDefault();
      if (!items.length) return;
      activeIndex = Math.min(activeIndex + 1, items.length - 1);
      updateActiveItem(items);
      return;
    }

    if (event.key === 'ArrowUp') {
      event.preventDefault();
      if (!items.length) return;
      activeIndex = Math.max(activeIndex - 1, 0);
      updateActiveItem(items);
      return;
    }

    if (event.key === 'Enter' && activeIndex >= 0 && items[activeIndex]) {
      event.preventDefault();
      window.location.href = items[activeIndex].url;
    }
  });

  document.addEventListener('keydown', (event) => {
    const isMac = navigator.platform.toUpperCase().includes('MAC');
    const modifier = isMac ? event.metaKey : event.ctrlKey;

    if (modifier && event.key.toLowerCase() === 'k') {
      event.preventDefault();
      if (modal.hidden) openModal();
      else closeModal();
    }
  });
</script>

<style>
  .search-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: start center;
    padding: 10vh 1rem 2rem;
  }

  .search-modal[hidden] {
    display: none;
  }

  .search-backdrop {
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / 45%);
    backdrop-filter: blur(2px);
  }

  .search-panel {
    position: relative;
    width: min(640px, 100%);
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: var(--bg-elevated);
    box-shadow: 0 20px 50px rgb(0 0 0 / 18%);
  }

  .search-panel-header {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  .search-panel-icon {
    flex-shrink: 0;
    color: var(--text-muted);
  }

  .search-input {
    flex: 1;
    border: none;
    background: transparent;
    color: var(--text);
    font-size: 1rem;
    outline: none;
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-close {
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg);
    color: var(--text-muted);
    font-size: 0.75rem;
    padding: 0.2rem 0.45rem;
    cursor: pointer;
  }

  .search-hint {
    margin: 0.75rem 0 0.5rem;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .search-results {
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 340px;
    overflow-y: auto;
  }

  .search-result-item a {
    display: block;
    padding: 0.75rem 0.65rem;
    border-radius: 8px;
    color: inherit;
    text-decoration: none;
  }

  .search-result-item.is-active a,
  .search-result-item a:hover {
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .search-result-title {
    display: block;
    font-weight: 600;
    line-height: 1.4;
  }

  .search-result-meta {
    display: block;
    margin-top: 0.15rem;
    font-size: 0.8rem;
    color: var(--accent);
  }

  .search-result-desc {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .search-empty {
    margin: 0.5rem 0 0;
    padding: 1rem;
    border-radius: 8px;
    background: var(--bg);
    color: var(--text-muted);
    font-size: 0.9rem;
    text-align: center;
  }

  .search-footer {
    margin: 0.75rem 0 0;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    font-size: 0.82rem;
    color: var(--text-muted);
  }
</style>
